# Database
DATABASE_URL=postgresql://open-claude-tag:open-claude-tag@localhost:5432/open-claude-tag
# Launcher database backend: embedded (default, no Docker), docker, or external.
# OPEN_TAG_DB_MODE=embedded

# API
PORT=3000
# Open-access mode: when true, all Feishu senders are treated as OWNER (no DB role lookup).
# Suitable for private/internal single-team deployments for a better out-of-box experience.
# Set to false to enforce strict RBAC (required for multi-user or public-facing deployments).
OPEN_ACCESS=true
# Optional isolated dev overrides
# API_PORT=3101
# OPEN_TAG_INSTANCE_ROLE=isolated
# OPEN_TAG_INSTANCE_ID=card1
# RELOAD_MARKER_PATH=/tmp/open-claude-tag/isolated/card1/reload-marker.json
# OPEN_TAG_API_PID_PATH=/tmp/open-claude-tag/isolated/card1/api.pid.json
# OPEN_TAG_WORKER_PID_PATH=/tmp/open-claude-tag/isolated/card1/worker.pid.json
HOST=0.0.0.0
LOG_LEVEL=info

# Default working directory for new sessions. When set to an absolute path,
# every newly created session is seeded with `adhocWorkDir` pointing at it,
# so the worker runs tasks there via passthrough (creates a worktree if it's
# a git repo, otherwise uses the directory directly). Relative or empty
# values are dropped silently. The API logs a startup warning when the
# configured path does not exist, but the value is still stored on new
# sessions and tasks will fail when they try to use it — fix the env or
# the directory before they run.
# Existing sessions are not retroactively rebound; self_dev / /dev tasks
# always use the bot's own monorepo regardless of this setting.
# When the prompt-metadata extractor (OPEN_TAG_LLM_*) is configured,
# stickiness is preserved across turns; without it the seeded value still
# applies on the first task via the worker's no-LLM fallback.
# OPEN_TAG_DEFAULT_WORKDIR=/absolute/path/to/your/project

# Server-centralized mode (see doc/deployment/server-mode.md)
# Public base URL user daemons dial; rendered into /machine connect pairing cards.
# Required only when remote execution daemons are used.
# SERVER_PUBLIC_URL=https://open-claude-tag.example.com
# Worker-hosted daemon gateway (pairing REST + daemon WebSocket).
# DAEMON_GATEWAY_PORT=3001
# Binds loopback unless explicitly made public (set true behind a TLS reverse proxy).
# DAEMON_GATEWAY_PUBLIC=false
# Per-daemon dispatch cap (read on the daemon host). The daemon rejects with
# `busy` when full; absent ⇒ no daemon-side cap.
# OPEN_TAG_DAEMON_MAX_CONCURRENT_DISPATCHES=

# Feishu (required — obtain from Feishu Developer Console)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# FEISHU_EVENT_MODE=websocket
# FEISHU_WEBHOOK_PATH=/webhooks/feishu
# FEISHU_ENCRYPT_KEY=
# FEISHU_VERIFICATION_TOKEN=

# Optional, on-demand local Feishu two-bot E2E validation.
# Store real values only in your gitignored .env. These are used by
# `pnpm lark:setup-two-bot-e2e`; they are not part of default test gates.
# FEISHU_LOCAL_E2E_BOT1_APP_ID=
# FEISHU_LOCAL_E2E_BOT1_APP_SECRET=
# FEISHU_LOCAL_E2E_BOT1_AGENT_HANDLE=codex-mac
# FEISHU_LOCAL_E2E_BOT1_AGENT_DISPLAY_NAME=OpenClaudeTagBot1
# FEISHU_LOCAL_E2E_BOT2_APP_ID=
# FEISHU_LOCAL_E2E_BOT2_APP_SECRET=
# FEISHU_LOCAL_E2E_BOT2_AGENT_HANDLE=reviewer
# FEISHU_LOCAL_E2E_BOT2_AGENT_DISPLAY_NAME=OpenClaudeTagBot2

# Slack channel (optional, experimental — see README "Slack Setup").
# OAuth / multi-workspace install, Socket Mode, and rich worker-side completion
# delivery are not built yet. Configure these only to enable the Slack channel.
# SLACK_SIGNING_SECRET enables and signature-verifies the POST /slack/events route.
# SLACK_SIGNING_SECRET=
# SLACK_BOT_USER_ID: when set, an @mention of this bot dispatches a task.
# SLACK_BOT_USER_ID=
# SLACK_BOT_TOKEN: Slack Web API token used to send the inbound ACK.
# SLACK_BOT_TOKEN=

# Runtime - Claude Code
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Configure either ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN.
# If both are set, ANTHROPIC_API_KEY takes precedence.
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
# Default runtime for general tasks: claude_code (default) or codex.
# OPEN_TAG_DEFAULT_RUNTIME=claude_code
# Optional default model override.
# OPEN_TAG_DEFAULT_MODEL=

# Worker
WORKER_CONCURRENCY=5
# OPEN_TAG_REPO_ROOT defaults to process.cwd(); override when running
# from a different directory than the repo root (e.g. in Docker).
# OPEN_TAG_REPO_ROOT=/path/to/OpenClaudeTag
# Auto-restart worker when it is detected as down. Primary-role only.
# WORKER_AUTO_RESTART=false
# WORKER_RESTART_COOLDOWN_MS=30000
# Worker executor: set to "tmux" to launch the worker inside a named tmux
# session (requires tmux). /reload will then restart it in the same session.
# WORKER_EXECUTOR=tmux
# Custom tmux session name (defaults to open-claude-tag-worker-<instanceId>).
# WORKER_EXECUTOR_SESSION=open-claude-tag-worker

# Codex startup timeout: max ms to wait for the Codex process to establish its
# API connection. Guards against TCP SYN_SENT hangs. Set to 0 to disable.
# CODEX_STARTUP_TIMEOUT_MS=120000

# Worker auto-restart: set to 'true' to automatically restart the worker when
# it is detected as down. Primary-role instances only.
# WORKER_AUTO_RESTART=false
# WORKER_RESTART_COOLDOWN_MS=30000

# Runtime - Codex (uses ~/.codex/config.toml)
# Max ms to wait for Codex to establish its API connection. Guards against TCP hangs.
# CODEX_STARTUP_TIMEOUT_MS=120000

# Buffer-until-AT mode: when true, normal messages are silently stored without
# creating a task. Only @bot mentions trigger task creation, aggregating all
# buffered user messages since the last task (up to 25) into a single goal.
# Primarily useful for P2P (DM) chats. Defaults to false (current behavior).
# BUFFER_UNTIL_AT=false

# Channel observation memory ("following the channel"): when enabled (the
# default), every inbound human message — addressed (@mention) or not — is folded
# into channel-scoped observation memory. The write is non-blocking and
# error-isolated, so it never delays or breaks task dispatch. Bots, slash
# commands, empty, and sensitive content are skipped automatically. Set to
# `disabled` to turn the tap off globally (a finer per-channel toggle is a later
# refinement). Default ON; only the literal value `disabled` turns it off.
# OPEN_TAG_CHANNEL_MEMORY=disabled

# Ambient proactive posting (opt-in, default OFF). Judge-gated proactive replies
# when the channel is discussing something relevant. OPEN_TAG_AMBIENT_CHANNELS is
# an optional channel allowlist.
# OPEN_TAG_AMBIENT=enabled
# OPEN_TAG_AMBIENT_CHANNELS=

# Stale-thread nudge scanner (opt-in, default OFF; see ADR-0007). Nudges idle
# threads. OPEN_TAG_STALE_THREAD_CHANNELS is an optional channel allowlist.
# OPEN_TAG_STALE_THREAD_SCANNER_ENABLED=true
# OPEN_TAG_STALE_THREAD_CHANNELS=

# Cross-channel flag broker master switch (default OFF; see ADR-0006).
# Experimental: the broker is implemented but not yet wired into the live path.
# OPEN_TAG_CROSS_CHANNEL_ENABLED=true

# Worktree cleanup (primary API background loop). Defaults: 7 days retention,
# 5 minute scan interval.
# WORKTREE_RETENTION_MS=604800000
# WORKTREE_CLEANUP_INTERVAL_MS=300000

# OpenClaudeTag LLM Client (for workdir extraction and agent-level tasks)
# Uses an OpenAI-compatible API endpoint
# OPEN_TAG_LLM_PROVIDER=openai
# OPEN_TAG_LLM_BASE_URL=https://your-openai-compatible-endpoint/api/v3
# OPEN_TAG_LLM_API_KEY=your-api-key
# OPEN_TAG_LLM_MODEL=your-model
