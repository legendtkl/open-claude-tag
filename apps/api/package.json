{
  "name": "@open-tag/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=../../.env src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "test:integration": "OPEN_TAG_API_PG_INTEGRATION=1 vitest run src/__tests__/admin-api-ownership.test.ts src/__tests__/slack-inbound-dispatch.test.ts src/__tests__/slack-task-dispatch.integration.test.ts src/__tests__/stale-thread-scanner.integration.test.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --reporter=verbose"
  },
  "dependencies": {
    "@open-tag/ambient": "workspace:*",
    "@open-tag/approval": "workspace:*",
    "@open-tag/channel-core": "workspace:*",
    "@open-tag/channel-slack": "workspace:*",
    "@open-tag/core-types": "workspace:*",
    "@open-tag/cross-channel": "workspace:*",
    "@open-tag/feishu-adapter": "workspace:*",
    "@open-tag/llm-client": "workspace:*",
    "@open-tag/memory": "workspace:*",
    "@open-tag/observability": "workspace:^",
    "@open-tag/orchestrator": "workspace:*",
    "@open-tag/queue": "workspace:*",
    "@open-tag/registry": "workspace:^",
    "@open-tag/runtime-adapters": "workspace:*",
    "@open-tag/session": "workspace:*",
    "@open-tag/storage": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "jose": "^5.9.6",
    "pino": "^9.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
