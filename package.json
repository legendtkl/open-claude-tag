{
  "name": "open-claude-tag",
  "private": true,
  "version": "0.1.0",
  "description": "OpenClaudeTag vendor-neutral engineering assistant for team chat with pluggable channels and runtimes",
  "license": "MIT",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @open-tag/api run dev",
    "dev:console": "pnpm --filter @open-tag/console run dev",
    "dev:desktop": "VITE_OPEN_TAG_DESKTOP=1 pnpm --filter @open-tag/console run build && pnpm --filter @open-tag/desktop run dev",
    "dev:worker": "pnpm --filter @open-tag/worker run dev",
    "build:desktop": "VITE_OPEN_TAG_DESKTOP=1 pnpm --filter @open-tag/console run build && pnpm --filter @open-tag/desktop run build",
    "dist:desktop:mac": "VITE_OPEN_TAG_DESKTOP=1 pnpm --filter @open-tag/console run build && pnpm --filter @open-tag/desktop run dist:mac",
    "dist:desktop:mac:signed": "VITE_OPEN_TAG_DESKTOP=1 pnpm --filter @open-tag/console run build && pnpm --filter @open-tag/desktop run dist:mac:signed",
    "start:local": "node tools/local/manage.mjs start",
    "start:desktop:local": "pnpm start:local && OPEN_TAG_API_URL=http://127.0.0.1:3000 pnpm dev:desktop",
    "stop:local": "node tools/local/manage.mjs stop",
    "restart:local": "node tools/local/manage.mjs restart",
    "status:local": "node tools/local/manage.mjs status",
    "logs:api": "tail -f /tmp/open-claude-tag/primary/api.log",
    "logs:worker": "tail -f /tmp/open-claude-tag/primary/worker.log",
    "dev:api:isolated": "node tools/instance/run.mjs exec --ensure-db -- pnpm --filter @open-tag/api run dev",
    "dev:worker:isolated": "node tools/instance/run.mjs exec --ensure-db -- pnpm --filter @open-tag/worker run dev",
    "services:start": "node tools/instance/run.mjs services-start",
    "services:stop": "node tools/instance/run.mjs services-stop",
    "services:restart": "node tools/instance/run.mjs services-restart",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,yaml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,yaml,md}\"",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm -r run test:integration",
    "test:integration:isolated": "node tools/instance/run.mjs exec -- pnpm test:integration",
    "test:e2e": "pnpm -r run test:e2e",
    "test:e2e:isolated": "node tools/instance/run.mjs exec -- pnpm --filter @open-tag/api test:e2e",
    "test:runtime:e2e": "pnpm --filter @open-tag/runtime-adapters run test:runtime:e2e",
    "db:migrate": "pnpm --filter @open-tag/storage run db:migrate",
    "db:seed": "pnpm --filter @open-tag/storage run db:seed",
    "db:setup": "pnpm db:migrate && pnpm db:seed",
    "db:generate": "pnpm --filter @open-tag/storage run db:generate",
    "db:create:isolated": "node tools/instance/run.mjs ensure-db",
    "db:migrate:isolated": "node tools/instance/run.mjs exec --ensure-db -- pnpm --filter @open-tag/storage run db:migrate",
    "db:seed:isolated": "node tools/instance/run.mjs exec --ensure-db -- pnpm --filter @open-tag/storage run db:seed",
    "db:setup:isolated": "pnpm db:create:isolated && pnpm db:migrate:isolated && pnpm db:seed:isolated",
    "env:instance": "node tools/instance/run.mjs print",
    "isolated:ps": "node tools/instance/run.mjs isolated-ps",
    "isolated:stop": "node tools/instance/run.mjs isolated-stop",
    "isolated:reap": "node tools/instance/run.mjs isolated-reap",
    "isolated:purge": "node tools/instance/run.mjs isolated-purge",
    "setup:local": "node tools/setup/local.mjs",
    "doctor:local": "node tools/setup/doctor.mjs",
    "personal:up": "node packages/launcher/dist/cli.js up",
    "personal:down": "node packages/launcher/dist/cli.js down",
    "personal:status": "node packages/launcher/dist/cli.js status",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "lark:doctor": "lark-cli doctor",
    "lark:send": "lark-cli im +messages-send",
    "lark:search": "lark-cli im +chat-search",
    "lark:test-card": "bash tools/lark/send-test-card.sh",
    "lark:setup-two-bot-e2e": "node tools/instance/run.mjs exec --ensure-db -- node tools/lark/setup-local-two-bot-e2e.mjs",
    "lark:personal-two-bot-e2e": "node tools/lark/personal-two-bot-e2e.mjs",
    "ops:health-alert": "node tools/ops/service-health-alert.mjs",
    "ops:health-alert:test": "node --test tools/ops/service-health-alert.test.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.1"
  }
}
