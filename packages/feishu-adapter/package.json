{
  "name": "@open-tag/feishu-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "OPEN_TAG_FEISHU_PG_INTEGRATION=1 vitest run src/__tests__/dedup.integration.test.ts"
  },
  "dependencies": {
    "@open-tag/channel-core": "workspace:*",
    "@open-tag/core-types": "workspace:*",
    "@open-tag/observability": "workspace:^",
    "@open-tag/storage": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "pino": "^9.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
