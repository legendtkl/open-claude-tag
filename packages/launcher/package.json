{
  "name": "@open-tag/launcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "open-claude-tag": "./dist/cli.js",
    "oct": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "test:unit": "vitest run",
    "prove:embedded": "tsx src/scripts/prove-embedded.ts"
  },
  "dependencies": {
    "embedded-postgres": "https://registry.npmjs.org/embedded-postgres/-/embedded-postgres-16.14.0-beta.17.tgz",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
